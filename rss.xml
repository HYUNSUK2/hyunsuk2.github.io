    <item>
      <title>하둡 공부 순서</title>
      <link>http://hyunsuk2.github.io/2021/02/23/hadoop-study-order/</link>
      <guid>http://hyunsuk2.github.io/2021/02/23/hadoop-study-order/</guid>
